services:
  anonymousoverflow:
    container_name: anonymousoverflow
    image: codeberg.org/aryak/anonymousoverflow-docker-builds@sha256:8ab06b3f63f9b696fe5a466e806266caa8ad892cb908852b424dd0c831ed08ef
    environment:
      - APP_URL=overflow.{{ services_domain }}
      - JWT_SIGNING_SECRET={{ anonymousoverflow_secret }}
    restart: unless-stopped
    read_only: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    networks:
      - services

networks:
  services:
    external: true
