services:
  anonymousoverflow:
    container_name: anonymousoverflow
    image: codeberg.org/aryak/anonymousoverflow-docker-builds@sha256:d95c4618d0bd6d0549e0ec569340dff851769851931a113f81447163cef0888b
    environment:
      - APP_URL=overflow.{{ services_domain }}
      - JWT_SIGNING_SECRET={{ anonymousoverflow_secret }}
    restart: unless-stopped
    read_only: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    networks:
      - services

networks:
  services:
    external: true
